# Variables d'environnement pour le développement local (sans Docker)
# Copier ce fichier en .env et remplir les valeurs

# ── Backend ──
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=germs_dev
DB_USER=germs_user
DB_PASSWORD=germs_dev_password

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──
JWT_SECRET=dev-jwt-secret-change-in-production

# ── CORS ──
CORS_ORIGIN=http://localhost:5173

# ── Services externes (optionnel pour dev) ──
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# WHATSAPP_API_KEY=
# FIREBASE_PROJECT_ID=
# MAPBOX_TOKEN=

# ══════════════════════════════════════════
# CLOUD GRATUIT (pour déploiement)
# ══════════════════════════════════════════

# ── Neon (PostgreSQL gratuit) ──
# Créer un compte sur https://neon.tech
# DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/germs_dev?sslmode=require

# ── Upstash (Redis gratuit) ──
# Créer un compte sur https://upstash.com
# UPSTASH_REDIS_URL=redis://default:xxx@eu1-xxx.upstash.io:6379

# ── Render (Backend gratuit) ──
# Déployer via render.yaml

# ── Vercel (Dashboard gratuit) ──
# VITE_API_URL=https://germs-backend.onrender.com
# VITE_WS_URL=wss://germs-backend.onrender.com
